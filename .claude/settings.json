{
  "permissions": {
    "allow": [
      "Bash(codex exec:*)",
      "Bash(gemini -p *:*)",
      "Bash(gemini --resume *:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/harness_gate_check.sh"
          }
        ]
      }
    ]
  }
}
